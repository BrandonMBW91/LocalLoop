# Copy this file to ".env" (same folder) and fill in your service-role key.
# .env is gitignored — it will NOT be committed. Never paste the key in chat.
#
# Find the key in Supabase: Project Settings → API → "service_role" secret.

SUPABASE_URL=https://wtaefyspddadcrnovumk.supabase.co
SUPABASE_SERVICE_ROLE_KEY=paste-your-service_role-key-here

# Optional: enables AI category labels (Music/Family/Arts/…) for events.
# Get one at console.anthropic.com → API Keys. Without it, events keep the
# coarse category from their source feed.
ANTHROPIC_API_KEY=paste-your-anthropic-api-key-here
