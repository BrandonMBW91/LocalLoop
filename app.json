{
  "expo": {
    "name": "Local Loop",
    "slug": "local-loop",
    "scheme": "localloop",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "primaryColor": "#1F6F54",
    "description": "Local events, garage sales, and food trucks across Northwest Ohio.",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.michaelwilliams.localloop",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.michaelwilliams.localloop",
      "adaptiveIcon": {
        "backgroundColor": "#1F6F54",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": []
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Local Loop uses your photos so you can add pictures to a garage sale post.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      "expo-font",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-monochrome.png",
          "color": "#1F6F54"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4b1bddaa-1419-4967-94d0-5a3c9a966582"
      }
    },
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/4b1bddaa-1419-4967-94d0-5a3c9a966582"
    }
  }
}
