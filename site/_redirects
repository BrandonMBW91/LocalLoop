# Serve the Apple App Site Association from a non-hidden file — Netlify zip
# deploys drop dot-directories, so /.well-known/ 404s. This rewrite (200, not
# redirect) serves the JSON with the right path for iOS universal links.
/.well-known/apple-app-site-association  /aasa.json  200

# Deep-link paths: when the app is installed, iOS Universal Links / Android App
# Links intercept these before the browser. When it isn't, serve a small
# interstitial (200 rewrite, URL preserved) that routes iOS to the App Store and
# points Android users to the test build — instead of dead-ending Android users
# on an iOS-only App Store page.
/event/*         /open.html  200
/garage-sale/*   /open.html  200
/food-truck/*    /open.html  200
