# Copy this file to ".env" and paste in your Supabase project's keys.
# Find them in the Supabase dashboard → Project Settings → API.
# Until these are set, the app runs on the bundled sample data.
#
# The EXPO_PUBLIC_ prefix is required — it tells Expo to include the value
# in the app. The anon key is safe to ship in a mobile app (your data is
# protected by the Row Level Security rules in supabase/schema.sql).

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# --- AdMob (real ads) — only used in a development/production build, not Expo Go.
# See docs/NATIVE_FEATURES.md. Leave unset to keep the placeholder ad.
# EXPO_PUBLIC_ADMOB_BANNER_ANDROID=ca-app-pub-XXXX/XXXX
# EXPO_PUBLIC_ADMOB_BANNER_IOS=ca-app-pub-XXXX/XXXX
