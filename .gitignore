# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Netlify (local site-link state)
.netlify/

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Saved dashboard pages (may contain secrets) — never commit
*.htm
*.html.bak

outreach/

# App Store Connect API key (secret)
.asc/
*.p8

# Google Play service-account key (secret) — never commit
.gcp/
*service-account*.json
play-service-account*.json

# Local Loop FB routine runtime state
.fb-featured.json
local-refresh.log
